{
  "settingsSync.ignoredExtensions": [
    "ms-toolsai.vscode-jupyter-slideshow",
    "ms-vscode-remote.remote-wsl"
  ],
  "emacs-mcx.strictEmacsMove": true,
  "emacs-mcx.useMetaPrefixMacCmd": true,
  "files.autoSave": "onFocusChange",
  "editor.tabSize": 2,
  "editor.cursorStyle": "block",
  "cSpell.userWords": [
    "admob",
    "chromeos",
    "crxjs",
    "Cupertino",
    "datetime",
    "deque",
    "dotenv",
    "endregion",
    "fediverse",
    "fromarray",
    "iframes",
    "imshow",
    "inapp",
    "jndex",
    "Kofi",
    "libc",
    "liistener",
    "lobste",
    "Localstore",
    "marugothic",
    "mkmk",
    "omnibox",
    "otsu",
    "Pinia",
    "pkce",
    "pomodoro",
    "posthog",
    "prefs",
    "prosemirror",
    "rakuten",
    "riverpod",
    "sidepanel",
    "speeddial",
    "sqflite",
    "squircle",
    "Supabase",
    "syncfusion",
    "timelapse",
    "tiptap",
    "unmark",
    "upsert",
    "vueuse",
    "Wakelock",
    "websidian",
    "worldnews"
  ],
  "workbench.layoutControl.enabled": false,
  "editor.formatOnSave": true,
  "editor.wordWrap": "on",
  "errorLens.statusBarMessageEnabled": true,
  "errorLens.gutterIconsEnabled": true,
  "errorLens.gutterIconSet": "letter",
  "errorLens.gutterIconSize": "85%",
  "errorLens.scrollbarHackEnabled": true,
  "errorLens.statusBarColorsEnabled": true,
  "errorLens.statusBarCommand": "copyMessage",
  "errorLens.statusBarIconsEnabled": true,
  "files.trimTrailingWhitespace": true,
  "editor.stickyScroll.enabled": true,
  "git.autofetch": true,
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "dart.debugExternalPackageLibraries": false,
  "dart.debugSdkLibraries": false,
  "git.openRepositoryInParentFolders": "never",
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "terminal.integrated.confirmOnExit": "always",
  "terminal.integrated.confirmOnKill": "always",
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.localEchoExcludePrograms": ["nano", "tmux"],
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.defaultLocation": "editor",
  "glassit.alpha": 220,
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "terminal.integrated.allowChords": false,
  "terminal.integrated.enableImages": true,
  "vscode-edge-devtools.webhintInstallNotification": true,
  "[css]": {
    "editor.defaultFormatter": "vscode.css-language-features"
  },
  "clipboard.size": 100,
  "redhat.telemetry.enabled": false,
  "workbench.startupEditor": "none",
  "dart.hotReloadOnSave": "all",
  "dart.hotReloadProgress": "statusBar",
  "dart.flutterHotReloadOnSave": "all",
  "magit.display-buffer-function": "same-column",
  "errorLens.followCursor": "closestProblemMultiline",
  "terminal.integrated.fontFamily": "Roboto Mono for Powerline",
  "liveServer.settings.donotShowInfoMsg": true,
  "[vue]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.formatOnPaste": true,
  "editor.formatOnType": true,
  "grammarly.files.include": [
    "**/readme.md",
    "**/README.md",
    "**/*.txt",
    "**/COMMIT_EDITMSG",
    "**/*.org",
    "**/*.md"
  ],
  "explorer.confirmDragAndDrop": false,
  "files.insertFinalNewline": true,
  "vue.updateImportsOnFileMove.enabled": true,
  "autoHide.autoHidePanel": false,
  "editor.fontFamily": "'Martian Mono', Menlo, Monaco, 'Courier New', monospace",
  "editor.codeLensFontFamily": "Martian Mono",
  "[cpp]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
  },
  "C_Cpp.intelliSenseEngine": "disabled",
  "notebook.formatOnSave.enabled": true,
  "autopep8.args": ["--indent-size=2"],
  "[python]": {
    "editor.defaultFormatter": "ms-python.autopep8"
  },
  "editor.detectIndentation": false,
  "github.copilot.editor.enableAutoCompletions": true,
  "workbench.editorAssociations": {
    "*.svg": "default"
  },
  "javascript.updateImportsOnFileMove.enabled": "always",
  "github.copilot.chat.localeOverride": "ja",
  "playwright.reuseBrowser": false,
  "playwright.showTrace": true,
  "diffEditor.hideUnchangedRegions.enabled": true,
  "accessibility.voice.speechLanguage": "ja-JP",
  "lldb.suppressUpdateNotifications": true,
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
  },
  "foam.files.newNotePath": "currentDir",
  "todo-tree.general.statusBar": "current file",
  "todo-tree.general.tags": ["[ ]", "[x]", "#TODO", "#DONE", "#date"],
  "todo-tree.highlights.customHighlight": {
    "#TODO": {
      "foreground": "#000000",
      "iconColour": "#808080",
      "background": "#FFFF00"
    },
    "#DONE": {
      "foreground": "#000000",
      "iconColour": "#FFFF00",
      "background": "#808080"
    },
    "[ ]": {
      "foreground": "#000000",
      "iconColour": "#808080",
      "background": "#FFFF00"
    },
    "[x]": {
      "foreground": "#000000",
      "iconColour": "#FFFF00",
      "background": "#808080"
    },
    "#date": {
      "foreground": "#000000",
      "iconColour": "#00FFFF",
      "background": "#00FFFF"
    }
  },
  "todo-tree.regex.regex": "(//|#|<!--|;|/\\*|^|^[ \\t]*(-|\\d+.))?\\s*($TAGS)\\b|\\b($TAGS)\\s*(//|#|<!--|;|/\\*|$)",
  "editor.multiCursorModifier": "ctrlCmd",
  "foam.completion.useAlias": "whenPathDiffersFromTitle",
  "markdown.preview.breaks": true,
  "markdownlint.run": "onSave",
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "markdownRunner.compilerOptions": {
    "cpp": " -std=c++17 -I/opt/homebrew/include -L/opt/homebrew/lib -lbenchmark"
  },
  "github.copilot.chat.editor.temporalContext.enabled": true,
  "chat.experimental.statusIndicator.enabled": true,
  "github.copilot.nextEditSuggestions.enabled": true
}
