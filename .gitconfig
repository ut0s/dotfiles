[user]
  name = Yuto TAGASHIRA
  email = ut0s.dev@gmail.com
[color]
  ui = true
  diff = auto
  status = auto
  branch = auto
[core]
  editor = nano
  quotepath = false
  pager = less -FRX
[merge]
  tool = meld
  ff = false
[push]
  default = matching

[pack]
  threads = 1

[ghq]
    root = ~/.go/src
    root = ~/git

[alias]
  gr = log --graph --all --format="%x09%C(cyan)%C(bold)%an%Creset%x09%C(yellow)%h%x09%Creset%C(green)%C(reverse)%d%Creset%x09%C(bold)%s"
  st = status
  ci = commit
  unstage = reset HEAD --
  br = branch
  last = log -1 HEAD

[commit]
  template = ~/dotfiles/doc/.developer.txt
[pull]
  ff = only
